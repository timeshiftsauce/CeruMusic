+    this.tray.setTitle(title, TITLE_OPTIONS)
+  }
+
+  private getCurrentLyricLine() {
+    if (!this.playStatus) {
+      return this.currentIndex >= 0 ? this.lyrics[this.currentIndex] || '' : ''
+    }
+    return this.currentIndex >= 0 ? this.lyrics[this.currentIndex] || '' : ''
+  }
+}
